n = -5:5;
x1 = zeros(1, length(n));
x2 = zeros(1, length(n));
offset = 5 + 1;
x1(offset) = 0;
x1(offset + 1) = 1;
x1(offset + 2) = 3;
x1(offset + 3) = -2;
x2(offset - 1) = 0;
x2(offset) = 1;
x2(offset + 1) = 2;
x2(offset + 2) = 3;
y = x1.*x2;
clf();
subplot(3,1,1);
plot2d3(n, x1);
title("x1(n)");
xlabel("n");
ylabel("x1(n)");
subplot(3,1,2);
plot2d3(n, x2);
title("x2(n)");
xlabel("n");
ylabel("x2(n)");
subplot(3,1,3);
plot2d3(n, y);
title("y(n) = x1(n).x2(n)");
xlabel("n");
ylabel("y(n)");
